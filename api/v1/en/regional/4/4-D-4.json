      "metadata": [
        
        {
                        "name": "4.D.4 Average number of pupils per 1 full-time teacher in primary schools for children and youth",
                      
                        "goal": "Goal 4. Quality education",
                      
                        "priority": "Creating conditions for improving the accessibility and effectiveness of education and equalizing educational opportunities. (Supporting education at all levels in the area of preparation for compulsory school-leaving exams)",
                      
                        "definition": "Average number of pupils per full-time teacher in primary schools for children and young people (excluding special).",
                      
                        "unit": "persons",
                      
                        "dimensions": "total",
                      
                        "methodology": "Primary school – an 8-year school (since 1 September 2017) where, in the last year of education, a compulsory eighth-grade examination is carried out to check the student’s or student’s knowledge and skills as set out in the general education curriculum. The organisational structure of primary schools includes classes I to VIII, where learning is compulsory. Until the 2016/2017 school year, the primary school was a 6-year school.Data on teachers concern teachers (including teachers of religion) employed in the implementation of existing educational activities, i.e. without after-school educators and librarians conducting only extra-curricular activities, etc. Only part-time related to the obligation to teach (without duties related to the function of educator, conducting extracurricular activities, due to the managerial function, etc.) was included.Data on teachers refer to full-time and part-time employees in terms of full-time employees. Full-time or part-time status has been assigned to all teachers regardless of the form of employment (e.g. also in the case of persons working under a contract of mandate or a contract for specific work).The student is a person attending school.In the 2009/10-2013/14 school years, 6-year-old children could start their education in the 1st grade of primary school at the request of their parents. In the 2014/15 school year, compulsory schooling was imposed on 6-year-old children born in the first half of 2008, and in the 2015/16 school year, compulsory schooling was already imposed on all 6-year-old children. From the 2016/17 school year, compulsory schooling was imposed on 7-year-old children, while at the request of parents, 6-year-old children can start their education in the 1st grade of primary school.Data as of 30 September.",
                      
                        "source": "Ministry of National Education",
                      
                        "availability": "Annual data, since 2011",
                      
                        "notes": "",
                      
                        "data_updated_on": "",
                      
                        "metadata_updated_on": ""
                      }
