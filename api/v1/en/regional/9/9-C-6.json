      "metadata": [
        
        {
                        "name": "9.C.6 Percentage of buses adjusted to carrying the disabled persons in urban transport",
                      
                        "goal": "Goal 9. Industry, innovation and infrastructure",
                      
                        "priority": "Strengthening the availability of transport infrastructure and the coherence of public communication in the region",
                      
                        "definition": "Percentage ratio of the number of buses adapted to transport disabled people to the total number of buses in public transport (as of December 31).",
                      
                        "unit": "percent",
                      
                        "dimensions": "total",
                      
                        "methodology": "Bus adapted for the transport of disabled persons - in accordance with Regulation No. 107 of the UN ECE (OJ EU L 153 of 18.06.2015 - Uniform provisions concerning the approval of vehicles of category M2 or M3 with regard to their general construction) all single-deck, double-deck, rigid or articulated vehicles must allow access for people with reduced mobility, including at least one wheelchair user, as well as doors with a lift or ramp providing access for people using wheelchairs.The data concerns bus transport (including express buses) in cities - including the service of suburban and intercity traffic remaining in the hands of public transport companies and private companies serving certain cities or specific lines.The data comes from the statistical report T-06 report on passenger road transport and covers the rolling stock of entities conducting municipal passenger transport in the scope of urban transport, including the service of suburban areas (full observation method).",
                      
                        "source": "Statistics Poland",
                      
                        "availability": "Annual data, since 2009",
                      
                        "notes": "",
                      
                        "data_updated_on": "",
                      
                        "metadata_updated_on": ""
                      }
