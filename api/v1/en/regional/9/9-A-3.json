      "metadata": [
        
        {
                        "name": "9.A.3 Share of industrial enterprises that cooperated in terms of innovation activity in total number of enterprises",
                      
                        "goal": "Goal 9. Industry, innovation and infrastructure",
                      
                        "priority": "Increased competitiveness of the region by increasing the research and innovation potential (Development of institutional potential for research and development, supporting cooperation between the research sector and the economy)",
                      
                        "definition": "Percentage ratio of industrial enterprises employing 10 or more persons cooperating in the field of innovation activities to all industrial enterprises.",
                      
                        "unit": "percent",
                      
                        "dimensions": "total",
                      
                        "methodology": "Industrial innovation enterprises are industrial enterprises that introduced at least one product innovation in business processes (new or improved product or new or improved business process) to the market in the period under review - until 2018 - process innovation (new or significantly improved product or new or significantly improved process).Cooperation in the field of innovation activity means active participation in joint projects concerning innovation activity with other enterprises or non-commercial institutions. Such cooperation may be prospective and long-term in nature and does not have to entail direct, measurable economic benefits for the participating partners. Simply ordering work from external contractors, without active participation in their implementation, should not be considered cooperation in the field of innovation activity.",
                      
                        "source": "Statistics Poland",
                      
                        "availability": "Annual data, since 2008; since 2022 data in two-year cycles",
                      
                        "notes": "",
                      
