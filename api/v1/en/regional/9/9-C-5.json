      "metadata": [
        
        {
                        "name": "9.C.5 Transport of passengers per 1 inhabitant of urban areas",
                      
                        "goal": "Goal 9. Industry, innovation and infrastructure",
                      
                        "priority": "Strengthening the availability of transport infrastructure and the coherence of public communication in the region",
                      
                        "definition": "The ratio of the number of passenger transport by public transport to the number of population in the cities.",
                      
                        "unit": "persons",
                      
                        "dimensions": "total",
                      
                        "methodology": "Transport of passengers by public transport is the sum of passengers transported by public transport, generally accessible to the public, i.e. buses, trams and trolleybuses. A single pass is considered a transported passenger by public transport. The number of passengers is estimated on the basis of the number of one-off and multi-trip tickets sold, taking into account the standards for the number of journeys for a given multi-pass ticket accepted by public transport establishments. Data refer to enterprises and municipal transport companies employing more than 9 people. Data on residents of urban areas were taken from statistical information on the number of population in cities according to the actual place of residence.",
                      
                        "source": "Ministry of Infrastructure",
                      
                        "availability": "Annual data, since 2010",
                      
                        "notes": "",
                      
                        "data_updated_on": "",
                      
                        "metadata_updated_on": ""
                      }
