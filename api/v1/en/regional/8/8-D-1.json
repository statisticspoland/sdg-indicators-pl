      "metadata": [
        
        {
                        "name": "8.D.1 Number of women who did not start work after childbirth per 10 thous. inhabitants",
                      
                        "goal": "Goal 8. Decent work and economic growth",
                      
                        "priority": "Professional activation, taking into account particularly socially vulnerable groups and shaping a friendly work environment",
                      
                        "definition": "The number of women, who after giving a birth, registered in the respective labour office to find a job per 10 thousand of population.",
                      
                        "unit": "persons",
                      
                        "dimensions": "total",
                      
                        "methodology": "The definition of registered unemployed persons is specified by the Law of 20 April 2004 on promoting employment and labour market institutions (Journal of Laws 2020 item 1409, with later amendments).An unemployed person is a person who is not employed or performing any other kind of paid work, available for full-time work (or in case of disabled persons — available for at least half of the full work-time required for a given occupation or service), are not attending any full-time school with the exception of schools for adults or taking an extra-curriculum exam in such schools or tertiary schools in the evening or weekend education system, and are registered in the powiat labour office respective to the person’s permanent or temporary place of residence, seeking employment or any other paid work if they, among others:1) is at least 18 years old and2) is less than 60 in case of women and less than 65 in case of men;3) did not become entitled to benefits from retirement pay or disability pension, family pension, education pension, social pension, does not receive pre-retirement benefit and allowance, rehabilitation benefit, sick benefit, maternity benefit or benefit of an amount equal to maternity benefit;4) is not an owner or a holder (independent or dependent) of an agricultural real estate with an area of agricultural land exceeding 2 convertible ha;5) is not eligible for retirement and disability insurance from constant work as a spouse or a household member on a farm with an area of agricultural land exceeding 2 convertible ha;6) does not have an entry in the register of economic activity or is not eligible –at the basis of separate legislation – for social insurance with an exception of farmers social insurance;7) is not a pre-trial detainee or a convicts serving punishment in prison;8) does not receive monthly income exceeding half of the monthly minimum wages and salaries for work excluding incomes received from interests or other incomes from cash kept on a bank accounts;9) does not receive permanent benefit on the basis of provisions of the regulations on social assistance;10) does not receive nursing benefit on the basis of provisions of the regulations on family allowances;11) does not receive training allowances after termination of employment.",
                      
                        "source": "Statistics Poland",
                      
                        "availability": "Annual data, since 2010",
                      
                        "notes": "",
                      
                        "data_updated_on": "",
                      
                        "metadata_updated_on": ""
                      }
      ],
