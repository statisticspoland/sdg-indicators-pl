      "metadata": [
        
        {
                        "name": "8.D.6 Number of registered unemployed persons with no work seniority per 1 thous. population",
                      
                        "goal": "Goal 8. Decent work and economic growth",
                      
                        "priority": "Professional activation, taking into account particularly socially vulnerable groups and shaping a friendly work environment",
                      
                        "definition": "The number of people who have not worked so far, registered in district labour offices as unemployed per 1000 population aged 18-59/64 years.",
                      
                        "unit": "persons",
                      
                        "dimensions": "total",
                      
                        "methodology": "Registered unemployed persons are persons who are aged 18 or more and have not reached the retirement age, are not employed or performing any other kind of paid work, available for full- time work and are registered in the powiat labour office respective to the person's permanent or temporary place of residence, seeking employment or any other paid work.Among the unemployed persons are included disabled persons—are able and ready to take employment at least half the full work-time required within a given occupation or service, are not attending any full-time school with the exception of schools for adults (or taking extra curriculum exam in such schools) or tertiary schools in the evening or weekend education system or seeking employment or any other paid work, with additional provisions concerning the sources of income, included in the mentioned law.Detailed criteria defining a registered unemployed person are set out in the Act of 20 April 2004 on the promotion of employment and labour market institutions (Journal of Laws No. Journal of Laws 2024, item 475, as amended).The number of unemployed persons registered without work experience was converted into 1000 people of working age, i.e. aged 18-59 years (women) or 18-64 years (men).Data as of 31 December.",
                      
                        "source": "Ministry of Family, Labour and Social Policy / Statistics Poland",
                      
                        "availability": "Annual data, since 2010",
                      
                        "notes": "",
                      
                        "data_updated_on": "",
                      
                        "metadata_updated_on": ""
                      }
