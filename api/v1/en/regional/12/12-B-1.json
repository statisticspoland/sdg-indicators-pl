      "metadata": [
        
        {
                        "name": "12.B.1 Recycling level of preparation for reuse and recovery of other than hazardous construction and demolition waste that is municipal waste",
                      
                        "goal": "Goal 12. Responsible consumption and production",
                      
                        "priority": "Supporting the development of a closed-loop economy model in order to rationally use resources and reduce the negative impact of manufactured products on the environment",
                      
                        "definition": "Percentage of non-hazardous construction and demolition waste that is municipal waste recycled, prepared for re-use or recovered.",
                      
                        "unit": "percent",
                      
                        "dimensions": "total",
                      
                        "methodology": "Waste recovery is any operation the principal result of which is waste serving a useful purpose by replacing other materials which would otherwise have been used to fulfil a particular function, or waste being prepared to fulfil that function, in the plant or in the wider economy.Recycling - any recovery operation by which waste materials are reprocessed into products, materials or substances whether for the original or other purposes. It includes the reprocessing of organic material but does not include energy recovery and the reprocessing into materials that are to be used as fuels or for backfilling operations.Municipal waste - waste generated in households, excluding end-of-life vehicles or generated by other waste producers (excluding hazardous waste) which on the account of its character and composition is similar to waste from households.",
                      
                        "source": "Statistics Poland / Chief Inspectorate of Environmental Protection / Ministry of Climate and Environment",
                      
                        "availability": "Annual data, since 2020",
                      
