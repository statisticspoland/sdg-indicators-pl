      "metadata": [
        
        {
                        "name": "2.B.1 Indices of gross agricultural output (previous year = 100)",
                      
                        "goal": "Goal 2. Zero hunger",
                      
                        "priority": "Ensuring food quality, safety and food security",
                      
                        "definition": "The ratio of the value of global agricultural production (at constant prices) in the year under review to the value of global agricultural production in the previous year.",
                      
                        "unit": "-",
                      
                        "dimensions": "total",
                      
                        "methodology": "Global agricultural production includes all agricultural production in the field of plant and animal production conducted by economic entities regardless of the PKD section to which they are classified. It concerns individual farms (in national accounts, an element of the Household Sector) and other farms producing agricultural production. Global agricultural production includes: - plant production, i.e. raw (unprocessed) products of plant origin (harvests of a given year), - animal production, i.e. production of slaughter livestock and raw (unprocessed) products of animal origin and growth in the number of farm animals (livestock - basic and rotating herd), which includes: cattle, pigs, sheep, horses and poultry. It is the sum of the values of: commercial production (purchase and sale at the market), natural consumption of agricultural products from own production (self-supply), increase in stocks of plant and animal products and increase in the value of the farm animal population (livestock - basic and circulating herd) and products from own production that were used for production purposes, e.g. feed, seed material, manure.",
                      
                        "source": "Statistics Poland",
                      
                        "availability": "Annual data, since 2013",
                      
