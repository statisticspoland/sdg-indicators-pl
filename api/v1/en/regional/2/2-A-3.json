      "metadata": [
        
        {
                        "name": "2.A.3 Gross agricultural output per 1 ha of agricultural land",
                      
                        "goal": "Goal 2. Zero hunger",
                      
                        "priority": "Increasing the competitiveness of farms and agri-food producers",
                      
                        "definition": "The value of global agricultural production (at constant prices) in the surveyed year divided by the area of agricultural land, expressed in PLN.",
                      
                        "unit": "PLN",
                      
                        "dimensions": "total",
                      
                        "methodology": "Global agricultural production includes all agricultural production in the field of plant and animal production conducted by economic entities regardless of the PKD section to which they are classified. It concerns individual farms (in national accounts, an element of the Household Sector) and other farms producing agricultural production. Global agricultural production includes: - plant production, i.e. raw (unprocessed) products of plant origin (harvests of a given year), - animal production, i.e. production of slaughter livestock and raw (unprocessed) products of animal origin and growth in the number of farm animals (livestock - basic and rotating herd), which includes: cattle, pigs, sheep, horses and poultry. It is the sum of the values of: commercial production (purchase and sale at the market), natural consumption of agricultural products from own production (self-supply), increase in stocks of plant and animal products and increase in the value of the livestock population (livestock - basic and turnover herd) and products from own production that were used for production purposes, e.g. feed, seed material, manure.  The area of agricultural land includes the area of agricultural land in good agricultural condition and other agricultural land. Agricultural land in good agricultural condition - maintained in accordance with standards meeting the requirements of the Act of 5 February 2015 on payments under direct support systems (consolidated text Journal of Laws 2015 item 308, with subsequent amendments) - is presented in the division into: area under sown crops, fallow land, permanent crops (including orchards), home gardens, permanent meadows and permanent pastures. Other agricultural land is agricultural land that is not used and not maintained in good condition. Data on the area of agricultural land from 2010 does not include land owned by owners of agricultural land who do not conduct agricultural activity and land owned by owners of less than 1 ha of agricultural land who conduct agricultural activity on a small scale (below specific thresholds).",
                      
                        "source": "Statistics Poland",
                      
                        "availability": "Annual data, since 2010",
                      
                        "notes": "",
                      
                        "data_updated_on": "",
                      
                        "metadata_updated_on": ""
                      }
