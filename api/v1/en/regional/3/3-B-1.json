      "metadata": [
        
        {
                        "name": "3.B.1 Number of beds in hospices, chronic medical care homes and nursing homes per 100 thous. population",
                      
                        "goal": "Goal 3. Good health and well-being",
                      
                        "priority": "Improving the quality and availability of healthcare infrastructure",
                      
                        "definition": "Number of beds in hospices, chronic medical care homes and nursing homes per 100 thous. population.",
                      
                        "unit": "pieces",
                      
                        "dimensions": "total",
                      
                        "methodology": "Bed – bed placed in the sick room which is regularly maintained and staffed and immediately available for the care of admitted patients. Beds in general hospitals do not include day-care beds, the beds (couches) included in the diagnostic, delivery, dialysis sites, etc. as well as auxiliary beds on which a patient is temporarily for instance post-procedure recovery beds.A hospice, a chronic medical care home and a nursing home are health care unit or organizational unit of the health care unit, in which the therapeutic entity conducts inpatient medical activity and 24-hour medical services other than hospital services.The hospice provides services consisting in particular of comprehensive health care, psychological and social care over patients in terminal phase of disease as well as over a families of these patients.Chronic medical care homes provides services consisting in particular in providing 24-hour health care services which cover the scope of nursing and rehabilitation of patients who do not require hospitalization and providing them with pharmaceutical agents and medical materials, accommodation and food appropriate to their health condition and also conducting health education for patients and members of their families and preparation these patients for self-care and personal care at home.Nursing homes provides services consisting in particular on providing 24-hour health care services which cover nursing and rehabilitation of patients who do not require hospitalization and providing them with pharmaceutical agents needed for continuation of a treatment, accommodation and food appropriate to their health condition and also conducting health education for patients and members of their families and preparation these patients for self-care.",
                      
                        "source": "Statistics Poland",
                      
                        "availability": "Annual data, since 2010",
                      
                        "notes": "",
                      
