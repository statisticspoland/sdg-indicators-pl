      "metadata": [
        
        {
                        "name": "5.A.5 Percentage of economically inactive persons due to family and household responsibilities",
                      
                        "goal": "Goal 5. Gender equality",
                      
                        "priority": "Activities supporting gender equality in families",
                      
                        "definition": "Percentage of persons aged 15-74 years who are economically inactive due to family and household responsibilities in the total economically inactive population of the same age group.",
                      
                        "unit": "percent",
                      
                        "dimensions": "total",
                      
                        "methodology": "The Labour Force Survey (LFS) is one of the basic the survey conducted by the Statistics Poland in the area of the labour market. This survey enables the current assessment of the degree of utilization of labour resources, and at the same time allows for a broader characterization of individual population groups distinguished by their status on the labour market (the employed, unemployed) or remaining outside the labour market (economically inactive persons). The LFS is the Polish edition of the Labour Force Survey /LFS and has been carried out in Poland on a quarterly since May 1992. This is a continuous survey carried out throughout the year on a research sample of the population staying or intending to stay in the country for at least 12 months, living in private households in randomly selected apartments.The economically inactive population by the LFS are people aged 15-89 years who were not classified as employed or unemployed, who who in the reference week:a)	did not work, neither had a job nor were seeking work,b)	did not work, were seeking a job, albeit not in an active way or were actively seeking work but were not ready (available) to start work within the two weeks following the reference week,c)	neither worked nor were seeking work, as they had already found a job and were waiting to start work during the period:- longer than 3 months,- up to 3 months, albeit they were not available for this work.In the LFS survey (since 2021), the reasons for inactivity is defined for the population of the economically inactive aged 15-74 years.",
                      
                        "source": "Statistics Poland",
                      
                        "availability": "Annual data, since 2019",
                      
                        "notes": "Since 2023, data for generalisation of the survey the Labour Force Survey (LFS) results over the overall population from balance of resident population of Poland compiled on the basis of the results of the National Population and Housing Census 2021.The presented data for the years 2021-2022 have been recalculated in accordance with the new generalisation basis, therefore, data are incomparable with earlier periods.",
                      
                        "data_updated_on": "",
                      
                        "metadata_updated_on": ""
                      }
