      "7-3-a": [
        {
          "metadata": [
            
            {
                            "name": "7.3.a Energy import dependency",
                          
                            "goal": "Goal 7. Affordable and clean energy",
                          
                            "priority": "Ensurance of energy security of the state",
                          
                            "definition": "Net energy imports divided by gross available energy, expressed as a percentage.",
                          
                            "unit": "percent [%]",
                          
                            "dimensions": "total, solid fossil fuels, natural gas, oil and petroleum products",
                          
                            "methodology": "The indicator measures the degree to which a country depends on imports of energy or raw materials used for energy production.The numerator is net energy imports, while the denominator is gross available energy. The reference period is the calendar year. The indicator is expressed as a percentage and is presented both as an aggregate measure for all energy sources and broken down by individual fuel categories, namely solid fossil fuels, natural gas, and oil and petroleum products (excluding the biofuel portion).A negative value of the indicator indicates net exports of energy, while a value exceeding 100% indicates the accumulation of energy stocks.Net energy imports are defined as the difference between the energy imported and exported by a given country.Gross available energy refers to the total supply of energy within the territory of a given country intended for all types of activity.The biofuel portion refers to fuel additives produced from biomass.",
                          
                            "source": "Eurostat",
                          
                            "availability": "Annual data; since 2010",
                          
                            "notes": "",
                          
