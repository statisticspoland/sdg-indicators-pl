      "7-1-b": [
        {
          "metadata": [
            
            {
                            "name": "7.1.b Final energy consumption per capita",
                          
                            "goal": "Goal 7. Affordable and clean energy",
                          
                            "priority": "Improvement of energy efficiency",
                          
                            "definition": "Final energy consumption per capita refers to the share of total energy consumed by end users across individual sectors of the economy attributable to one person.",
                          
                            "unit": "toe",
                          
                            "dimensions": "total",
                          
                            "methodology": "The indicator presents the level of final energy consumption per capita and supports the monitoring of energy consumption patterns.The numerator is total final energy consumption expressed in tonnes of oil equivalent (toe), while the denominator is the total population. The indicator is expressed on a per capita basis.The data required to calculate the indicator are provided by the European Statistical System (ESS), established under Regulation (EC) No 223/2009 of the European Parliament and of the Council. The ESS constitutes a partnership between Eurostat, national statistical institutes (for example, Statistics Poland), and other national authorities in each Member State responsible for the development, production and dissemination of European statistics.A tonne of oil equivalent (toe) is a standardised unit of energy used to compare different energy sources. The International Energy Agency (IEA) defines one tonne of oil equivalent (toe) as the amount of energy released by burning one tonne of crude oil with a net calorific value of 41 868 kJ/kg.Final energy consumption refers to energy consumed by end users in all sectors of the economy (for example, industry, transport, agriculture and households), excluding energy consumed by the energy sector itself. Final energy consumption also excludes losses occurring during the distribution of energy.The calculation of the indicator excludes the use of energy carriers for non-energy purposes (for example, the use of natural gas in the chemical industry as feedstock rather than as fuel).",
                          
                            "source": "Eurostat",
                          
                            "availability": "Annual data; since 2010",
                          
                            "notes": "",
                          
                            "data_updated_on": "",
                          
