      "metadata": [
        
        {
                        "name": "4.5.a Number of graduates from higher education in technical fields (natural sciences, mathematics, ICT, engineering, manufacturing and construction) per 1 thous. persons aged 20–29",
                      
                        "goal": "Goal 4. Quality education",
                      
                        "priority": "Improvement in education innovativeness",
                      
                        "definition": "Number of tertiary education graduates in technical fields (science, mathematics, computing, engineering, manufacturing, construction) per 1 000 persons aged 20–29 years.",
                      
                        "unit": "persons",
                      
                        "dimensions": "total, sex",
                      
                        "methodology": "The purpose of the indicator is to measure output of STEM-related tertiary education relative to young adult population.The numerator is the number of graduates in STEM fields in tertiary education in the given reference year. The denominator is the total population aged 20–29 years, based on the Eurostat data. The indicator is expressed per 1 000 persons.Data on the number of graduates are derived from the joint UOE (UNESCO–OECD–Eurostat) data collection on education statistics, based on administrative data reported by national statistical authorities and ministries responsible for education.A graduate is defined as a person who has successfully completed a programme of study at the tertiary education level (i.e. ISCED 2011 levels 5–8). STEM fields are defined in accordance with ISCED-F 2013 classification as follows: F05 (Natural sciences, mathematics and statistics), F06 (Information and Communication Technologies), and F07 (Engineering, manufacturing and construction).The International Standard Classification of Education (ISCED) is a framework for compiling, analysing and presenting internationally comparable statistics on education.",
                      
                        "source": "Eurostat",
                      
                        "availability": "Annual data, since 2014",
                      
