---
layout: null
sitemap: null
---

{% assign pages1 = site.metadane_globalne %}
[
  {% assign pages = site.metadane_krajowe %}
  {% assign pages2 = site.metadane_regionalne %}
  {% for page in pages %}
  {
    "indicator": {{ page.indicator | remove: ".0" | jsonify }},
    "title": {{ page.en_nazwa_wskaznika | jsonify }},
    "lang": {{ page.lang | jsonify }},
    "excerpt": {{ page.excerpt | markdownify | strip_html | jsonify }},
    "content": {{ page.content | markdownify | strip_html | jsonify }},
    "url": {{ site.baseurl | append: page.url | replace: "metadane_regionalne", "en/statistics_reg" | replace: "metadane_globalne", "en/statistics_glob" | replace: "metadane_krajowe", "en/statistics_nat" | replace: ".html", "/" | remove: "-0" | remove: "-reg" | jsonify }}
  },
  {% endfor %}
  {% for page in pages2 %}
  {
    "indicator": {{ page.indicator | remove: "-reg" | jsonify }},
    "title": {{ page.en_nazwa_wskaznika | jsonify }},
    "lang": {{ page.lang | jsonify }},
    "excerpt": {{ page.excerpt | markdownify | strip_html | jsonify }},
    "content": {{ page.content | markdownify | strip_html | jsonify }},
    "url": {{ site.baseurl | append: page.url | replace: "metadane_regionalne", "en/statistics_reg" | replace: "metadane_globalne", "en/statistics_glob" | replace: "metadane_krajowe", "en/statistics_nat" | replace: ".html", "/" | remove: "-0" | remove: "-reg" | jsonify }}
  },
  {% endfor %}
  {% for page in pages1 %}
  {
    "indicator": {{ page.indicator | remove: ".0" | jsonify }},
    "title": {{ page.en_nazwa_wskaznika | jsonify }},
    "lang": {{ page.lang | jsonify }},
    "excerpt": {{ page.excerpt | markdownify | strip_html | jsonify }},
    "content": {{ page.content | markdownify | strip_html | jsonify }},
    "url": {{ site.baseurl | append: page.url | replace: "metadane_regionalne", "en/statistics_reg" | replace: "metadane_globalne", "en/statistics_glob" | replace: "metadane_krajowe", "en/statistics_nat" | replace: ".html", "/" | remove: "-0" | remove: "-reg" | jsonify }}
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
